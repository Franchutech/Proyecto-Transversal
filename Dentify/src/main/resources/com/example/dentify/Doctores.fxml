<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>
<VBox prefHeight="650.0" prefWidth="850.0" styleClass="grid-pane" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.dentify.DentifyController">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="140.0" spacing="25.0" style="-fx-background-color: #0A3459;">
            <padding>
                <Insets left="30.0" />
            </padding>
            <children>
                <Button fx:id="btnVolver" prefHeight="57.0" prefWidth="62.0" styleClass="back-button">
                    <graphic>
                        <ImageView fx:id="btnFlechaVolver" fitHeight="106.0" fitWidth="102.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/volver.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                <VBox alignment="CENTER_LEFT">
                    <children>
                        <Label styleClass="title-main" text="Gestión de Doctores" />
                        <Label styleClass="subtitle-main" text="Administra la información de los doctores" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <VBox spacing="20.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
            </padding>
            <children>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <TextField fx:id="txtBuscar" promptText="Buscar paciente por nombre, apellido o teléfono..." styleClass="text-field-custom" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnNuevo" prefHeight="45.0" prefWidth="200.0" styleClass="success-button" text="+ Nuevo Paciente" />
                    </children>
                </HBox>

                <TableView fx:id="tablaDoctores" styleClass="panel-background" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colIdDoctor" prefWidth="50.0" text="ID" />
                        <TableColumn fx:id="colNombreDoctor" prefWidth="140.0" text="Nombre" />
                        <TableColumn fx:id="colFechaNacimiento" prefWidth="160.0" text="Fecha N." />
                        <TableColumn fx:id="colDireccion" prefWidth="110.0" text="Dirección" />
                        <TableColumn fx:id="colNumColegiado" prefWidth="180.0" text="Num. Colegiado" />
                        <TableColumn fx:id="colEspecialidad" prefWidth="130.0" text="Especialidad" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
